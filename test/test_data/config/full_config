# Comments '#' can be everywhere on the line, all subsequent chars will be ignored until '\n'.
# Spaces are not semantic (outside of key value separators) and can be either SP ot HTAB.
events {
	# the max number of simultaneous connections (client + server conections)
	# open sockets, Nginx use 2 connections at start
	max_connections 3;
}

http {
	autoindex	false;

	# Errors and include paths are relative to the config file
	error_page	500 501 502	html/50x.html;
	error_page	400			html/400.html;
	error_page	404			html/404.html;

	keepalive_timeout	10;
	max_body_size	1048576;

	# root paths are relative to the executable
	root	servers;

	# include raw file content (must be structured)
	include			mime.types; # fill 'types' block
	default_type	application/octet-stream;


	server {
		autoindex			true;
		error_page			404	html/404.html;
		listen				127.0.0.1:4242;
		root				servers/test/html;
		max_body_size		16384;
		return 				301 /newpage;

		storage /data/storage/ /real/path;

		location = / {
			autoindex		false;
			cgi				false;
			error_page		403	html/403.html;
			# ONLY IN CONFIG STRUCT # exact_match 	true; # If equal sign after location key
			index			index.html;
			limit_except	GET DELETE;
			return 301 /newpage;
			# root filesystem, absolute form or relative to server executable file
			# (if symlink resolve to source)
			# root			servers/test/html; // inherited
		}
		# if call /src return redirect
		# if call /src/ return index or list directory if autoindex on
		# location /src {
		# 	root	/home/juportie/Documents/webserv;
		# 	index	Config.h;
		# 	autoindex true;
		# }
	}
}

